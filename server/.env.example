# AI News Hub — server 환경 변수 (설계서 §4)
# 실제 값은 절대 커밋하지 않는다. 이 파일은 키와 형식 예시만 담는다.
# 로컬은 server/.env 에, 배포는 Render 환경 변수에 등록한다.

# Neon PostgreSQL 연결 문자열 (sslmode=require 포함)
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# /api/collect 인증용 시크릿. GitHub Secrets의 CRON_SECRET과 동일 값 (랜덤 32자 이상 권장)
CRON_SECRET=

# Gemini API 키 (AIza... 형식)
GEMINI_API_KEY=

# Gemini 무료 티어 모델명 (구현 시점 최신 무료 모델 확인 후 주입)
GEMINI_MODEL=

# 허용 CORS 오리진. 콤마로 다중 지정 가능 (로컬 개발 시 http://localhost:5173 추가)
CORS_ORIGIN=http://localhost:5173

# 서버 포트. Render는 자체 PORT를 주입하므로 배포 시 비워둬도 됨
PORT=3000
